# SSLCommerz Payment Gateway (Bangladesh)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_IS_LIVE=false

# Contact Information
NEXT_PUBLIC_COMPANY_NAME=GoFarm
NEXT_PUBLIC_COMPANY_EMAIL=support@gofarm.com
NEXT_PUBLIC_COMPANY_PHONE=+1 (555) 123-4567
NEXT_PUBLIC_COMPANY_ADDRESS=123 Shopping Street, Commerce District
